{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ZBar",
  "theme": "aspen",
  "colors": {
    "primary": "#dc0a7d",
    "light": "#0d8381",
    "dark": "#a0a193"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo.png",
    "dark": "/logo.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/mchehab/zbar"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/mchehab/zbar"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/barcode-types",
              "concepts/image-scanning",
              "concepts/video-capture"
            ]
          },
          {
            "group": "CLI Tools",
            "pages": [
              "cli/zbarcam",
              "cli/zbarimg"
            ]
          },
          {
            "group": "GUI Widgets",
            "pages": [
              "widgets/qt-widget",
              "widgets/gtk-widget"
            ]
          },
          {
            "group": "Language Bindings",
            "pages": [
              "bindings/python",
              "bindings/perl",
              "bindings/java"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/configuration",
              "advanced/v4l2-support",
              "advanced/dbus-integration"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "C API",
            "pages": [
              "api/image-scanner",
              "api/processor",
              "api/video",
              "api/window",
              "api/decoder",
              "api/scanner",
              "api/symbol",
              "api/image"
            ]
          },
          {
            "group": "C++ API",
            "pages": [
              "api/cpp/image-scanner",
              "api/cpp/processor",
              "api/cpp/video",
              "api/cpp/decoder"
            ]
          }
        ]
      }
    ]
  }
}
